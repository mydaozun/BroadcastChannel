---
const footerClass = 'hidden p-2 text-sm leading-normal text-footer md:block'
---

<footer class={footerClass}>
  Powered by
  <a
    href="https://github.com/miantiao-me/BroadcastChannel"
    title="BroadcastChannel"
    target="_blank"
    rel="noopener noreferrer"
  >
    BroadcastChannel
  </a>
 &
  <a
    href="https://iosapp.cc.cd"
    title="iosapp apple store限免应用情报局"
    target="_blank"
    rel="noopener noreferrer"
  >
    iosapp
  </a>
<!-- 新增：小程序二维码 -->
  <div style="margin-top: 12px; text-align: center;">
    <img 
      src="/xcx.png" 
      alt="小程序二维码" 
      style="max-width: 180px; height: auto; border: 1px solid #ddd; border-radius: 8px; padding: 4px; background: white;"
    >
    <div style="margin-top: 6px; font-size: 13px; color: #666;">微信小程序</div>
  </div>
  <script src="//cdn.busuanzi.cc/busuanzi/3.6.9/busuanzi.min.js" defer></script>
  <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid #e5e7eb; font-size: 13px; line-height: 1.8; color: #555;">
    <div>今日总访问量 <span id="busuanzi_today_pv">加载中...</span> 次</div>
    <div>今日总访客数 <span id="busuanzi_today_uv">加载中...</span> 人</div>
    <div>本站总访问量 <span id="busuanzi_site_pv">加载中...</span> 次</div>
    <div>本站总访客数 <span id="busuanzi_site_uv">加载中...</span> 人</div>
    <div>本页总阅读量 <span id="busuanzi_page_pv">加载中...</span> 次</div>
    <div>本页总访客数 <span id="busuanzi_page_uv">加载中...</span> 人</div>
</div>
</footer>
